<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>narreo — Flow into Transformation</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --olive:    #6A6528;
      --olive-lt: #8a862f;
      --orange:   #E15131;
      --cream:    #FAF8F2;
      --warm:     #F5EFE0;
      --dark:     #2a2618;
      --mid:      #6b6350;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--cream);
      color: var(--dark);
      overflow-x: hidden;
    }

    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 1.4rem 3rem;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(250,248,242,0.88);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(106,101,40,0.12);
    }

    .logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 300;
      letter-spacing: 0.25em;
      color: var(--olive);
      text-decoration: none;
    }

    .nav-cta {
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--orange);
      text-decoration: none;
      border-bottom: 1px solid var(--orange);
      padding-bottom: 2px;
      transition: opacity .2s;
    }
    .nav-cta:hover { opacity: 0.7; }

    .hero {
      min-height: 100vh;
      display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      text-align: center;
      padding: 7rem 2rem 5rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 160vw;
      height: 160vw;
      background: conic-gradient(
        from 0deg,
        transparent 0deg,   rgba(225,81,49,0.04) 3deg,
        transparent 6deg,   rgba(106,101,40,0.05) 9deg,
        transparent 12deg,  rgba(225,81,49,0.04) 15deg,
        transparent 18deg,  rgba(106,101,40,0.04) 21deg,
        transparent 24deg,  rgba(225,81,49,0.03) 27deg,
        transparent 30deg,  rgba(106,101,40,0.04) 33deg,
        transparent 36deg,  rgba(225,81,49,0.04) 39deg,
        transparent 42deg,  rgba(106,101,40,0.03) 45deg,
        transparent 48deg,  rgba(225,81,49,0.04) 51deg,
        transparent 54deg,  rgba(106,101,40,0.05) 57deg,
        transparent 60deg,  rgba(225,81,49,0.03) 63deg,
        transparent 66deg,  rgba(106,101,40,0.04) 69deg,
        transparent 72deg,  rgba(225,81,49,0.04) 75deg,
        transparent 78deg,  rgba(106,101,40,0.03) 81deg,
        transparent 84deg,  rgba(225,81,49,0.04) 87deg,
        transparent 90deg,  rgba(106,101,40,0.05) 93deg,
        transparent 96deg,  rgba(225,81,49,0.04) 99deg,
        transparent 102deg, rgba(106,101,40,0.04) 105deg,
        transparent 108deg, rgba(225,81,49,0.03) 111deg,
        transparent 114deg, rgba(106,101,40,0.04) 117deg,
        transparent 120deg, rgba(225,81,49,0.04) 123deg,
        transparent 126deg, rgba(106,101,40,0.03) 129deg,
        transparent 132deg, rgba(225,81,49,0.05) 135deg,
        transparent 138deg, rgba(106,101,40,0.04) 141deg,
        transparent 144deg, rgba(225,81,49,0.04) 147deg,
        transparent 150deg, rgba(106,101,40,0.03) 153deg,
        transparent 156deg, rgba(225,81,49,0.04) 159deg,
        transparent 162deg, rgba(106,101,40,0.04) 165deg,
        transparent 168deg, rgba(225,81,49,0.03) 171deg,
        transparent 174deg, rgba(106,101,40,0.05) 177deg,
        transparent 180deg, rgba(225,81,49,0.04) 183deg,
        transparent 186deg, rgba(106,101,40,0.04) 189deg,
        transparent 192deg, rgba(225,81,49,0.03) 195deg,
        transparent 198deg, rgba(106,101,40,0.04) 201deg,
        transparent 204deg, rgba(225,81,49,0.04) 207deg,
        transparent 210deg, rgba(106,101,40,0.04) 213deg,
        transparent 216deg, rgba(225,81,49,0.03) 219deg,
        transparent 222deg, rgba(106,101,40,0.05) 225deg,
        transparent 228deg, rgba(225,81,49,0.04) 231deg,
        transparent 234deg, rgba(106,101,40,0.04) 237deg,
        transparent 240deg, rgba(225,81,49,0.04) 243deg,
        transparent 246deg, rgba(106,101,40,0.03) 249deg,
        transparent 252deg, rgba(225,81,49,0.04) 255deg,
        transparent 258deg, rgba(106,101,40,0.04) 261deg,
        transparent 264deg, rgba(225,81,49,0.03) 267deg,
        transparent 270deg, rgba(106,101,40,0.05) 273deg,
        transparent 276deg, rgba(225,81,49,0.04) 279deg,
        transparent 282deg, rgba(106,101,40,0.04) 285deg,
        transparent 288deg, rgba(225,81,49,0.04) 291deg,
        transparent 294deg, rgba(106,101,40,0.03) 297deg,
        transparent 300deg, rgba(225,81,49,0.04) 303deg,
        transparent 306deg, rgba(106,101,40,0.04) 309deg,
        transparent 312deg, rgba(225,81,49,0.03) 315deg,
        transparent 318deg, rgba(106,101,40,0.05) 321deg,
        transparent 324deg, rgba(225,81,49,0.04) 327deg,
        transparent 330deg, rgba(106,101,40,0.04) 333deg,
        transparent 336deg, rgba(225,81,49,0.04) 339deg,
        transparent 342deg, rgba(106,101,40,0.03) 345deg,
        transparent 348deg, rgba(225,81,49,0.04) 351deg,
        transparent 354deg, rgba(106,101,40,0.05) 357deg,
        transparent 360deg
      );
      pointer-events: none;
      z-index: 0;
      animation: sun-rotate 80s linear infinite;
    }

    @keyframes sun-rotate {
      from { transform: translateX(-50%) rotate(0deg); }
      to   { transform: translateX(-50%) rotate(360deg); }
    }

    .hero::after {
      content: '';
      position: absolute;
      top: 12%;
      left: 50%;
      transform: translateX(-50%);
      width: 80px; height: 80px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(225,81,49,0.18) 0%, rgba(225,81,49,0.06) 50%, transparent 70%);
      z-index: 0;
    }

    .hero-inner { position: relative; z-index: 1; max-width: 780px; }

    .hero-tag {
      font-size: 0.7rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 2rem;
      display: block;
    }

    .hero-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(5rem, 18vw, 12rem);
      font-weight: 300;
      line-height: 0.9;
      color: var(--olive);
      letter-spacing: 0.06em;
      margin-bottom: 2.4rem;
    }

    .hero-divider {
      width: 48px;
      height: 1px;
      background: var(--orange);
      margin: 0 auto 2.4rem;
      opacity: 0.7;
    }

    .hero-tagline {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.1rem, 2.5vw, 1.45rem);
      font-weight: 300;
      font-style: italic;
      line-height: 1.6;
      color: var(--mid);
      max-width: 560px;
      margin: 0 auto 3.5rem;
    }

    .btn-primary {
      display: inline-block;
      padding: 0.95rem 2.8rem;
      background: var(--orange);
      color: #fff;
      text-decoration: none;
      font-size: 0.78rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      transition: background .2s, transform .2s;
      border-radius: 0;
    }
    .btn-primary:hover { background: #c94420; transform: translateY(-1px); }

    .words-strip {
      background: var(--olive);
      padding: 1.1rem 0;
      overflow: hidden;
    }
    .words-track {
      display: flex;
      gap: 3rem;
      animation: marquee 30s linear infinite;
      white-space: nowrap;
    }
    .word-item {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.05rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      color: rgba(250,248,242,0.75);
      text-transform: uppercase;
      flex-shrink: 0;
    }
    .word-dot { color: var(--orange); opacity: 0.8; }
    @keyframes marquee {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .about {
      padding: 8rem 2rem;
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.6fr;
      gap: 6rem;
      align-items: center;
    }

    .about-label {
      font-size: 0.68rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 1.5rem;
    }

    .about-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 300;
      line-height: 1.25;
      color: var(--olive);
    }

    .about-text {
      font-size: 0.97rem;
      line-height: 1.9;
      color: var(--mid);
      font-weight: 300;
    }
    .about-text p + p { margin-top: 1.2rem; }

    .vivian {
      background: var(--warm);
      padding: 8rem 2rem;
    }

    .vivian-inner {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
    }

    .vivian-photo-frame {
      width: 100%;
      aspect-ratio: 3/4;
      overflow: hidden;
      position: relative;
    }

    .vivian-photo-frame img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: top center;
      display: block;
    }

    .vivian-photo-frame::before,
    .vivian-photo-frame::after {
      content: '';
      position: absolute;
      width: 50px; height: 50px;
      z-index: 1;
    }
    .vivian-photo-frame::before {
      top: -8px; left: -8px;
      border-top: 1.5px solid var(--orange);
      border-left: 1.5px solid var(--orange);
    }
    .vivian-photo-frame::after {
      bottom: -8px; right: -8px;
      border-bottom: 1.5px solid var(--olive);
      border-right: 1.5px solid var(--olive);
    }

    .vivian-placeholder {
      width: 100%;
      aspect-ratio: 3/4;
      background: linear-gradient(160deg, rgba(106,101,40,0.12), rgba(225,81,49,0.08));
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .vivian-placeholder span {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      color: var(--mid);
      text-transform: uppercase;
      opacity: 0.5;
    }

    .vivian-text .about-label { margin-bottom: 1rem; }

    .vivian-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.5rem);
      font-weight: 300;
      color: var(--olive);
      line-height: 1.15;
      margin-bottom: 0.3rem;
    }

    .vivian-subtitle {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1rem;
      color: var(--orange);
      margin-bottom: 2rem;
    }

    .vivian-bio {
      font-size: 0.95rem;
      line-height: 1.85;
      color: var(--mid);
      font-weight: 300;
    }

    .limbic {
      padding: 8rem 2rem;
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
    }

    .section-label {
      font-size: 0.68rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 1rem;
    }

    .section-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 300;
      color: var(--olive);
      margin-bottom: 4rem;
    }

    .words-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 2px;
    }

    .word-cell {
      padding: 2.2rem 1rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.6rem;
      border: 1px solid rgba(106,101,40,0.1);
      transition: background .25s;
    }
    .word-cell:hover { background: rgba(225,81,49,0.05); }

    .word-number {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: var(--orange);
      opacity: 0.6;
    }

    .word-label {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 400;
      color: var(--olive);
      letter-spacing: 0.05em;
    }

    .contact {
      background: var(--olive);
      padding: 9rem 2rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .contact::before {
      content: '';
      position: absolute;
      bottom: -30%;
      left: 50%;
      transform: translateX(-50%);
      width: 90vw; height: 90vw;
      max-width: 800px; max-height: 800px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(225,81,49,0.15) 0%, transparent 65%);
      pointer-events: none;
    }

    .contact-inner { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }

    .contact-eyebrow {
      font-size: 0.68rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(225,81,49,0.8);
      margin-bottom: 1.5rem;
    }

    .contact-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 300;
      color: var(--cream);
      line-height: 1.3;
      margin-bottom: 1.8rem;
    }

    .contact-sub {
      font-size: 0.95rem;
      line-height: 1.8;
      color: rgba(250,248,242,0.65);
      font-weight: 300;
      margin-bottom: 3rem;
    }

    .contact-email-link {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      font-style: italic;
      color: rgba(250,248,242,0.9);
      text-decoration: none;
      margin-bottom: 3rem;
      letter-spacing: 0.05em;
      transition: color .2s;
    }
    .contact-email-link:hover { color: var(--orange); }

    .btn-light {
      display: inline-block;
      padding: 0.95rem 2.8rem;
      border: 1px solid rgba(250,248,242,0.4);
      color: var(--cream);
      text-decoration: none;
      font-size: 0.78rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      transition: background .2s, border-color .2s;
    }
    .btn-light:hover {
      background: rgba(250,248,242,0.1);
      border-color: rgba(250,248,242,0.7);
    }

    footer {
      padding: 2rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(106,101,40,0.12);
    }

    .footer-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      font-weight: 300;
      letter-spacing: 0.25em;
      color: var(--olive);
      text-decoration: none;
    }

    .footer-copy {
      font-size: 0.72rem;
      color: var(--mid);
      opacity: 0.5;
      letter-spacing: 0.1em;
    }

    @media (max-width: 720px) {
      nav { padding: 1.2rem 1.5rem; }
      .about { grid-template-columns: 1fr; gap: 2.5rem; padding: 5rem 1.5rem; }
      .vivian-inner { grid-template-columns: 1fr; gap: 3rem; }
      .vivian { padding: 5rem 1.5rem; }
      .vivian-photo-frame, .vivian-placeholder { max-width: 320px; margin: 0 auto; }
      .words-grid { grid-template-columns: repeat(2, 1fr); }
      .limbic { padding: 5rem 1.5rem; }
      .contact { padding: 6rem 1.5rem; }
      footer { flex-direction: column; gap: 0.8rem; text-align: center; }
    }
  </style>
</head>
