      <span class="word-item">Herzlichkeit <span class="word-dot">·</span></span>
      <span class="word-item">Mut <span class="word-dot">·</span></span>
      <span class="word-item">Freiheit <span class="word-dot">·</span></span>
      <span class="word-item">Humor <span class="word-dot">·</span></span>
      <span class="word-item">Natur <span class="word-dot">·</span></span>
